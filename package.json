{
    "name": "nanvc",
    "description": "Not Another Node Vault Client :)",
    "version": "1.0.15",
    "author": {
        "name": "Ionut Zailic",
        "email": "ionut@zailic.com"
    },
    "contributors": [],
    "keywords": [
        "hashicorp",
        "vault",
        "consul",
        "aws",
        "secrets",
        "manage",
        "client"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/zailic/nanvc.git"
    },
    "homepage": "https://github.com/zailic/nanvc",
    "bugs": {
        "url": "https://github.com/zailic/nanvc/issues"
    },
    "license": "MIT",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "dist/main.js",
    "types": "dist/main.d.ts",
    "exports": {
        ".": {
            "types": "./dist/main.d.ts",
            "import": "./dist/main.js"
        }
    },
    "scripts": {
        "clean": "rimraf dist coverage .nyc_output",
        "typecheck": "tsc -p tsconfig.json",
        "build": "npm run clean && tsc -p tsconfig.build.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test:integration:prepare": "sh ./test/util/vault/generate-certs.sh",
        "test": "npm run test:unit",
        "test:unit": "mocha --config .mocharc.json \"test/unit/**/*.ts\"",
        "test:integration": "mocha --config .mocharc.json \"test/integration/**/*.ts\"",
        "test:all": "mocha --config .mocharc.json \"test/unit/**/*.ts\" \"test/integration/**/*.ts\"",
        "coverage": "nyc npm run test:all",
        "prepack": "npm run build"
    },
    "nyc": {
        "include": [
            "src/**/*.ts",
            "src/**/*.tsx"
        ],
        "exclude": [
            "test/**/*.ts",
            "test/**/*.tsx"
        ],
        "extension": [
            ".ts",
            ".tsx"
        ],
        "require": [
            "tsx/cjs"
        ],
        "reporter": [
            "text-summary",
            "html",
            "lcov"
        ],
        "sourceMap": true,
        "instrument": true
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "tv4": "1.3.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/chai": "^5.2.3",
        "@types/mocha": "^10.0.0",
        "@types/node": "^20.0.0",
        "@types/sinon": "^21.0.0",
        "@types/tv4": "^1.2.0",
        "eslint": "^10.0.1",
        "mocha": "^11.0.0",
        "nyc": "^18.0.0",
        "rimraf": "^6.0.0",
        "sinon": "^21.0.3",
        "typescript": "^6.0.0",
        "typescript-eslint": "^8.58.0",
        "tsx": "^4.21.0"
    }
}
