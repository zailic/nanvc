{
  "compilerOptions": {
    "rootDir": "./src",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": false,
    "strict": true,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "removeComments": true,
    "esModuleInterop": true,
    "target": "es2020",
    "types": [
      "node"
    ],
    "lib": [
      "es2020"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "test",
    "src/stub.ts"
  ]
}
