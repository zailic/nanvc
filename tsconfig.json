{
  "compilerOptions": {
    "rootDir": "./src",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": false,
    "strict": true,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "removeComments": true,
    "esModuleInterop": true,
    "target": "es2020",
    "types": [
      "node"
    ],
    "lib": [
      "es2020"
    ]
  },
  "include": [
    "src/**/*.ts",
    "examples/app-role/main.ts",
    "examples/app-role-v1/main.ts",
    "examples/request-wrapping/main.ts"
  ],
  "exclude": [
    "examples",
    "node_modules",
    "test"
  ]
}
